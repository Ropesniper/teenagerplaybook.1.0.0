# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — only commit this .env.example file.

PORT=3000
MONGO_URI=your_mongodb_connection_string_here
JWT_SECRET=generate_a_long_random_string_here

ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
ADMIN_EMAIL=your_email@example.com

# Cloudinary (for persistent video/file storage)
# Sign up at https://cloudinary.com/users/register_free
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_UPLOAD_PRESET=teenager_playbook_videos
